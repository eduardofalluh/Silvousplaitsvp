# Copy to .env for local Netlify dev (netlify dev).
# Current setup uses honeypot only – no env vars required.
# If you add reCAPTCHA later, set your secret in Netlify only (never commit real keys).

# ============================================
# Stripe Payment Configuration (Premium Subscriptions)
# ============================================

# Stripe API Keys (Get from: https://dashboard.stripe.com/apikeys)
# For testing, use test keys (pk_test_... and sk_test_...)
# For production, use live keys (pk_live_... and sk_live_...)
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key

# Stripe Webhook Secret (Get from: https://dashboard.stripe.com/webhooks)
# Create a webhook endpoint pointing to: your-site.com/.netlify/functions/stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price ID for Premium Subscription
# Create a product and price in Stripe Dashboard, then copy the price ID (price_...)
STRIPE_PREMIUM_PRICE_ID=price_your_premium_price_id

# Site URL (for redirects after payment)
URL=https://silvousplaitsvp.com

# ============================================
# ActiveCampaign Configuration
# ============================================

# ActiveCampaign API (Get from: Settings > Developer)
ACTIVECAMPAIGN_API_URL=https://youraccountname.api-us1.com
ACTIVECAMPAIGN_API_KEY=your_api_key_here

# Optional: ActiveCampaign form endpoint used by Netlify signup forwarding.
# If omitted, defaults to https://silvousplait.activehosted.com/proc.php
ACTIVECAMPAIGN_FORM_URL=https://youraccountname.activehosted.com/proc.php

# ActiveCampaign Premium List ID (Optional - List for premium members)
ACTIVECAMPAIGN_PREMIUM_LIST_ID=your_premium_list_id

# ActiveCampaign Premium Tag (Optional - Tag for active premium members)
ACTIVECAMPAIGN_PREMIUM_TAG=premium_active

# Tag added when a ticket is sent via send-tickets.js
ACTIVECAMPAIGN_TICKET_SENT_TAG=ticket-sent

# Premium redemption security (used by send-tickets.js + redeem endpoint)
PREMIUM_ACCESS_SECRET=replace_with_a_long_random_secret
PREMIUM_ACCESS_BASE_URL=https://silvousplaitsvp.com
PREMIUM_ACCESS_TTL_DAYS=30
PREMIUM_REDEEMED_TAG_PREFIX=redeemed
PREMIUM_TALLY_FORM_URL=https://tally.so/r/682j2B
PREMIUM_OTP_TTL_MINUTES=10
PREMIUM_ACCESS_URL_FIELD_ID=123
PREMIUM_TOKEN_ADMIN_KEY=replace_with_a_long_random_admin_key

# ============================================
# Ticket Automation Configuration
# ============================================

# SMTP Settings (Required for sending emails with attachments)
# Get these from ActiveCampaign: Settings > Advanced > SMTP
SMTP_HOST=smtp.activehosted.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Email Sender Info
SENDER_EMAIL=contact@silvousplait.com
SENDER_NAME=Silvousplait

# Tickets File Path (supports .csv or .xlsx - defaults to tickets.csv)
TICKETS_FILE=tickets.csv

# Feature Toggles
ENABLE_TRACKING=true              # Track sent tickets to prevent duplicates
ENABLE_PREMIUM_CHECK=false        # Check if recipient is premium member
PREMIUM_ONLY=false                # Only send to premium members
USE_MOCK_PREMIUM=false            # Use mock data for testing premium features

# ============================================
# Zapier Integration (Optional)
# ============================================

# Zapier Webhook URL for ticket automation
# Set this up in Zapier and paste the webhook URL here
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/your_webhook_url
