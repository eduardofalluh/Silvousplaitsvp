# Copy to .env for local Netlify dev (netlify dev).
# Current setup uses honeypot only – no env vars required.
# If you add reCAPTCHA later, set your secret in Netlify only (never commit real keys).

# ============================================
# Ticket Automation Configuration
# ============================================

# SMTP Settings (Required for sending emails with attachments)
# Get these from ActiveCampaign: Settings > Advanced > SMTP
SMTP_HOST=smtp.activehosted.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Email Sender Info
SENDER_EMAIL=contact@silvousplait.com
SENDER_NAME=Silvousplait

# ActiveCampaign API (Optional - for contact tracking)
# Get these from ActiveCampaign: Settings > Developer
AC_API_URL=https://youraccountname.api-us1.com
AC_API_KEY=your_api_key_here

# CSV File Path (defaults to tickets.csv if not specified)
CSV_FILE=tickets.csv
